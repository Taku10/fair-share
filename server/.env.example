# MongoDB connection string (required)
MONGO_URI=mongodb://localhost:27017/fairshare

# Server port (optional, defaults to 5000)
PORT=5000

# Firebase Admin — choose one of the options below:

# Option A: Path to a Firebase service account JSON file
# SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccountKey.json

# Option B: Firebase credentials as individual environment variables
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option C: Local development auth bypass (NODE_ENV must be development or test)
# NODE_ENV=development
# ALLOW_DEV_AUTH=true
# DEV_FIREBASE_UID=dev-uid-1
# DEV_EMAIL=dev@local
# DEV_NAME=Dev User
